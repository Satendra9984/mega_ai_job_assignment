# Copy this file to .env and adjust as needed.
# The defaults below work for local Docker Compose development.
# Never commit .env to version control.

# --- Database ---
POSTGRES_USER=megaai
POSTGRES_PASSWORD=megaai  # CHANGE THIS before any non-local deployment
POSTGRES_DB=megaai
# DATABASE_URL: use localhost when Uvicorn runs on your PC (native Postgres or Docker
# publishing port 5432). Docker Compose overrides this for the backend container to host `db`.
# Create role/database per docs/SPRINT_1/LOCAL_POSTGRES_NATIVE.md if needed.
DATABASE_URL=postgresql+asyncpg://megaai:megaai@localhost:5432/megaai

# --- Backend ---
MAX_FRAME_BYTES=1048576          # 1 MB max per frame
DETECTION_CONFIDENCE=0.5         # MediaPipe min_detection_confidence (0.0 – 1.0)
MAX_WS_CONNECTIONS_PER_IP=5      # Soft in-memory per-IP guard for /ws/ingest
# CORS: Docker UI uses :3000. Vite dev (npm run dev) uses :5173 — include both if you mix modes, e.g.:
#   CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# --- Frontend (build-time, injected by Vite) ---
VITE_WS_BASE=ws://localhost:3000
VITE_API_BASE=http://localhost:3000
